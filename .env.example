# Supabase project settings used only by Vercel API functions.
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=replace-with-service-role-key

# Used to sign short-lived session tokens when demo mode is active.
VETBARA_SESSION_SECRET=replace-with-long-random-secret

# Enables built-in demo QR tokens when Supabase is unavailable or unseeded.
VETBARA_DEMO_MODE=true

# Required to call POST /api/seed for demo QR token bootstrap.
VETBARA_SEED_SECRET=replace-with-long-random-secret
